# Production: https://www.nd-compassion.ci
# Pour que le local se comporte comme la production, utilisez les mêmes
# variables que sur Vercel (Settings → Environment Variables).

# Obligatoire (Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optionnel (buckets storage)
# VITE_BUCKET_AVATAR=avatars
# VITE_BUCKET_GALLERY=gallery
# VITE_BUCKET_VIDEO_FILES=video-files
# VITE_BUCKET_PUBLIC=public
# VITE_BUCKET_DIRECTORY_IMAGES=directory-images
# VITE_BUCKET_PAROISSE_FILES=paroisse-files
# VITE_BUCKET_PAROISSES=paroisses
# VITE_BUCKET_PODCASTS=podcasts

# Optionnel (Edge / paiement)
# VITE_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1
# VITE_SUPABASE_PROJECT_ID=your-project-id
